@model CitasApp.Domain.Models.Medico

@{
    ViewData["Title"] = "Detalle del Médico";
}

<div class="page-header">
    <span class="section-kicker">Médico</span>
    <h1>@Model.Nombre @Model.Apellido</h1>
    <p>Perfil profesional y especialidad médica.</p>
</div>

<div class="card app-card detail-card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Nombre</dt>
            <dd class="col-sm-9">@Model.Nombre</dd>

            <dt class="col-sm-3">Apellido</dt>
            <dd class="col-sm-9">@Model.Apellido</dd>

            <dt class="col-sm-3">Especialidad</dt>
            <dd class="col-sm-9">@Model.Especialidad</dd>

            <dt class="col-sm-3">Licencia</dt>
            <dd class="col-sm-9">@Model.NumeroLicencia</dd>
        </dl>
    </div>
</div>

<a class="btn btn-outline-secondary mt-3" asp-action="Index">Volver</a>
