@model Citas.App.Models.Paciente

@{
    ViewData["Title"] = "Detalle del Paciente";
}

<div class="page-header">
    <span class="section-kicker">Paciente</span>
    <h1>@Model.Nombre @Model.Apellido</h1>
    <p>Información principal del paciente.</p>
</div>

<div class="card app-card detail-card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Nombre</dt>
            <dd class="col-sm-9">@Model.Nombre</dd>

            <dt class="col-sm-3">Apellido</dt>
            <dd class="col-sm-9">@Model.Apellido</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Teléfono</dt>
            <dd class="col-sm-9">@Model.Telefono</dd>
        </dl>
    </div>
</div>

<a class="btn btn-outline-secondary mt-3" asp-action="Index">Volver</a>
