<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Citas Médicas</title>

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Citas.App.sln.styles.css" asp-append-version="true" />
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark app-navbar">
            <div class="container">

                <a class="navbar-brand fw-semibold"
                   asp-controller="Home"
                   asp-action="Index">
                    CitasApp
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarPrincipal"
                        aria-controls="navbarPrincipal"
                        aria-expanded="false"
                        aria-label="Toggle navigation">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="collapse navbar-collapse" id="navbarPrincipal">

                    <ul class="navbar-nav ms-auto gap-lg-2">

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Index">
                                Inicio
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Paciente"
                               asp-action="Index">
                                Pacientes
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Medico"
                               asp-action="Index">
                                Médicos
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Cita"
                               asp-action="Index">
                                Agenda
                            </a>
                        </li>

                    </ul>

                </div>

            </div>
        </nav>
    </header>

    <div class="container app-shell">

        <main role="main" class="pb-4">
            @RenderBody()
        </main>

    </div>

    <footer class="app-footer footer text-muted">
        <div class="container">

            &copy; 2026 - Citas Médicas -
            <a asp-controller="Home"
               asp-action="Privacy">
                Privacidad
            </a>

        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
